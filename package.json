{
  "name": "claude-code-browser",
  "displayName": "Claude Code Browser",
  "description": "Browse and invoke Claude Code skills, agents, MCP servers, and plugins",
  "version": "0.24.1",
  "publisher": "chase-bowers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bowers-Enterprises/claude-code-browser.git"
  },
  "homepage": "https://github.com/Bowers-Enterprises/claude-code-browser#readme",
  "bugs": {
    "url": "https://github.com/Bowers-Enterprises/claude-code-browser/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "ai",
    "skills",
    "agents",
    "mcp"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-code-browser",
          "title": "Claude Code Browser",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "claude-code-browser": [
        {
          "id": "claudeCodeBrowser.skills",
          "name": "Skills",
          "when": "claudeCodeBrowser.panel.skills"
        },
        {
          "id": "claudeCodeBrowser.agents",
          "name": "Agents",
          "when": "claudeCodeBrowser.panel.agents"
        },
        {
          "id": "claudeCodeBrowser.mcpServers",
          "name": "MCP Servers",
          "when": "claudeCodeBrowser.panel.mcpServers"
        },
        {
          "id": "claudeCodeBrowser.plugins",
          "name": "Plugins",
          "when": "claudeCodeBrowser.panel.plugins"
        },
        {
          "id": "claudeCodeBrowser.commands",
          "name": "Commands",
          "when": "claudeCodeBrowser.panel.commands"
        },
        {
          "id": "claudeCodeBrowser.marketplace",
          "name": "Marketplace",
          "when": "claudeCodeBrowser.panel.marketplace"
        },
        {
          "id": "claudeCodeBrowser.hookManager",
          "name": "Hook Manager",
          "when": "claudeCodeBrowser.panel.hookManager"
        },
        {
          "id": "claudeCodeBrowser.agentTeams",
          "name": "Agent Teams",
          "when": "claudeCodeBrowser.panel.agentTeams"
        },
        {
          "id": "claudeCodeBrowser.worktrees",
          "name": "Worktrees",
          "when": "claudeCodeBrowser.panel.worktrees"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeCodeBrowser.invokeResource",
        "title": "Invoke Resource"
      },
      {
        "command": "claudeCodeBrowser.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeCodeBrowser.search",
        "title": "Search",
        "icon": "$(search)"
      },
      {
        "command": "claudeCodeBrowser.clearFilter",
        "title": "Clear Filter",
        "icon": "$(close)"
      },
      {
        "command": "claudeCodeBrowser.createFolder",
        "title": "New Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "claudeCodeBrowser.renameFolder",
        "title": "Rename Folder"
      },
      {
        "command": "claudeCodeBrowser.deleteFolder",
        "title": "Delete Folder"
      },
      {
        "command": "claudeCodeBrowser.createSubfolder",
        "title": "New Subfolder",
        "icon": "$(new-folder)"
      },
      {
        "command": "claudeCodeBrowser.moveToFolder",
        "title": "Move to Folder..."
      },
      {
        "command": "claudeCodeBrowser.moveToRoot",
        "title": "Move to Root"
      },
      {
        "command": "claudeCodeBrowser.copyCommand",
        "title": "Copy Command"
      },
      {
        "command": "claudeCodeBrowser.createPrompt",
        "title": "New Prompt",
        "icon": "$(add)"
      },
      {
        "command": "claudeCodeBrowser.editPrompt",
        "title": "Edit Prompt"
      },
      {
        "command": "claudeCodeBrowser.deletePrompt",
        "title": "Delete Prompt"
      },
      {
        "command": "claudeCodeBrowser.exportPrompts",
        "title": "Export Prompts",
        "icon": "$(export)"
      },
      {
        "command": "claudeCodeBrowser.importPrompts",
        "title": "Import Prompts",
        "icon": "$(import)"
      },
      {
        "command": "claudeCodeBrowser.marketplace.installSkill",
        "title": "Install Skill",
        "icon": "$(cloud-download)"
      },
      {
        "command": "claudeCodeBrowser.marketplace.viewOnGitHub",
        "title": "View on GitHub",
        "icon": "$(link-external)"
      },
      {
        "command": "claudeCodeBrowser.marketplace.refresh",
        "title": "Refresh Marketplace",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeCodeBrowser.marketplace.addSource",
        "title": "Add Skill Source",
        "icon": "$(add)"
      },
      {
        "command": "claudeCodeBrowser.marketplace.removeSource",
        "title": "Remove Source"
      },
      {
        "command": "claudeCodeBrowser.marketplace.installSourceSkill",
        "title": "Install Skill",
        "icon": "$(cloud-download)"
      },
      {
        "command": "claudeCodeBrowser.marketplace.viewSourceSkillOnGitHub",
        "title": "View on GitHub",
        "icon": "$(link-external)"
      },
      {
        "command": "claudeCodeBrowser.marketplace.refreshSource",
        "title": "Refresh Source",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeCodeBrowser.managePanels",
        "title": "Manage Panels",
        "icon": "$(list-unordered)"
      },
      {
        "command": "claudeCodeBrowser.showAllPanels",
        "title": "Show All Panels"
      },
      {
        "command": "claudeCodeBrowser.previewSkill",
        "title": "Preview Skill",
        "icon": "$(open-preview)"
      },
      {
        "command": "claudeCodeBrowser.convertToGlobalSkill",
        "title": "Convert to Global Skill",
        "icon": "$(globe)"
      },
      {
        "command": "claudeCodeBrowser.previewAgent",
        "title": "Preview Agent",
        "icon": "$(open-preview)"
      },
      {
        "command": "claudeCodeBrowser.previewMcp",
        "title": "Preview MCP Config",
        "icon": "$(open-preview)"
      },
      {
        "command": "claudeCodeBrowser.generateResearchPrompt",
        "title": "Create Skill from Research",
        "icon": "$(lightbulb)"
      },
      {
        "command": "claudeCodeBrowser.editSkill",
        "title": "Edit Skill",
        "icon": "$(edit)"
      },
      {
        "command": "claudeCodeBrowser.deleteSkill",
        "title": "Delete Skill",
        "icon": "$(trash)"
      },
      {
        "command": "claudeCodeBrowser.editAgent",
        "title": "Edit Agent",
        "icon": "$(edit)"
      },
      {
        "command": "claudeCodeBrowser.deleteAgent",
        "title": "Delete Agent",
        "icon": "$(trash)"
      },
      {
        "command": "claudeCodeBrowser.revealInFinder",
        "title": "Reveal in Finder"
      },
      {
        "command": "claudeCodeBrowser.copyPath",
        "title": "Copy Path"
      },
      {
        "command": "claudeCodeBrowser.duplicateSkill",
        "title": "Duplicate Skill"
      },
      {
        "command": "claudeCodeBrowser.renameSkill",
        "title": "Rename Skill"
      },
      {
        "command": "claudeCodeBrowser.duplicateAgent",
        "title": "Duplicate Agent"
      },
      {
        "command": "claudeCodeBrowser.renameAgent",
        "title": "Rename Agent"
      },
      {
        "command": "claudeCodeBrowser.exportBundle",
        "title": "Export as Bundle",
        "icon": "$(package)"
      },
      {
        "command": "claudeCodeBrowser.importBundle",
        "title": "Import Bundle",
        "icon": "$(cloud-download)"
      },
      {
        "command": "claudeCodeBrowser.editResearchTemplate",
        "title": "Edit Research Prompt Template",
        "icon": "$(edit)"
      },
      {
        "command": "claudeCodeBrowser.hooks.add",
        "title": "Add Hook",
        "icon": "$(add)"
      },
      {
        "command": "claudeCodeBrowser.hooks.edit",
        "title": "Edit Hook",
        "icon": "$(edit)"
      },
      {
        "command": "claudeCodeBrowser.hooks.delete",
        "title": "Delete Hook",
        "icon": "$(trash)"
      },
      {
        "command": "claudeCodeBrowser.hooks.toggle",
        "title": "Toggle Hook"
      },
      {
        "command": "claudeCodeBrowser.hooks.duplicate",
        "title": "Duplicate Hook"
      },
      {
        "command": "claudeCodeBrowser.hooks.openFile",
        "title": "Open Settings File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "claudeCodeBrowser.refreshHookManager",
        "title": "Refresh Hooks",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeCodeBrowser.refreshAgentTeams",
        "title": "Refresh Teams",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeCodeBrowser.agentTeams.watch",
        "title": "Watch Agent",
        "icon": "$(eye)"
      },
      {
        "command": "claudeCodeBrowser.worktree.create",
        "title": "Create Worktree",
        "icon": "$(add)"
      },
      {
        "command": "claudeCodeBrowser.worktree.resume",
        "title": "Resume Worktree"
      },
      {
        "command": "claudeCodeBrowser.worktree.openInEditor",
        "title": "Open in New Window",
        "icon": "$(multiple-windows)"
      },
      {
        "command": "claudeCodeBrowser.worktree.delete",
        "title": "Delete Worktree",
        "icon": "$(trash)"
      },
      {
        "command": "claudeCodeBrowser.worktree.launchTask",
        "title": "Launch Parallel Task",
        "icon": "$(zap)"
      },
      {
        "command": "claudeCodeBrowser.refreshWorktrees",
        "title": "Refresh Worktrees",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeCodeBrowser.openSkillFile",
        "title": "Open File"
      },
      {
        "command": "claudeCodeBrowser.skills.checkForUpdates",
        "title": "Check for Updates",
        "icon": "$(cloud-download)"
      },
      {
        "command": "claudeCodeBrowser.skills.updateSkill",
        "title": "Update Skill",
        "icon": "$(cloud-download)"
      },
      {
        "command": "claudeCodeBrowser.skills.updateAll",
        "title": "Update All Skills",
        "icon": "$(sync)"
      },
      {
        "command": "claudeCodeBrowser.skills.backfillSources",
        "title": "Backfill Skill Sources"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeCodeBrowser.generateResearchPrompt",
          "when": "view == claudeCodeBrowser.skills",
          "group": "navigation@0"
        },
        {
          "command": "claudeCodeBrowser.editResearchTemplate",
          "when": "view == claudeCodeBrowser.skills",
          "group": "template@1"
        },
        {
          "command": "claudeCodeBrowser.importBundle",
          "when": "view == claudeCodeBrowser.skills",
          "group": "import@1"
        },
        {
          "command": "claudeCodeBrowser.skills.checkForUpdates",
          "when": "view == claudeCodeBrowser.skills",
          "group": "updates@1"
        },
        {
          "command": "claudeCodeBrowser.skills.updateAll",
          "when": "view == claudeCodeBrowser.skills",
          "group": "updates@2"
        },
        {
          "command": "claudeCodeBrowser.skills.backfillSources",
          "when": "view == claudeCodeBrowser.skills",
          "group": "updates@3"
        },
        {
          "command": "claudeCodeBrowser.createFolder",
          "when": "view == claudeCodeBrowser.skills",
          "group": "navigation@1"
        },
        {
          "command": "claudeCodeBrowser.createFolder",
          "when": "view == claudeCodeBrowser.agents",
          "group": "navigation@1"
        },
        {
          "command": "claudeCodeBrowser.createFolder",
          "when": "view == claudeCodeBrowser.mcpServers",
          "group": "navigation@1"
        },
        {
          "command": "claudeCodeBrowser.createFolder",
          "when": "view == claudeCodeBrowser.plugins",
          "group": "navigation@1"
        },
        {
          "command": "claudeCodeBrowser.refresh",
          "when": "view =~ /claudeCodeBrowser\\./ && view != claudeCodeBrowser.commands && view != claudeCodeBrowser.marketplace && view != claudeCodeBrowser.hookManager && view != claudeCodeBrowser.agentTeams && view != claudeCodeBrowser.worktrees",
          "group": "navigation@2"
        },
        {
          "command": "claudeCodeBrowser.clearFilter",
          "when": "view =~ /claudeCodeBrowser\\./ && claudeCodeBrowser.filterActive",
          "group": "navigation@3"
        },
        {
          "command": "claudeCodeBrowser.search",
          "when": "view =~ /claudeCodeBrowser\\./",
          "group": "navigation@4"
        },
        {
          "command": "claudeCodeBrowser.createPrompt",
          "when": "view == claudeCodeBrowser.commands",
          "group": "navigation@1"
        },
        {
          "command": "claudeCodeBrowser.exportPrompts",
          "when": "view == claudeCodeBrowser.commands",
          "group": "navigation@5"
        },
        {
          "command": "claudeCodeBrowser.importPrompts",
          "when": "view == claudeCodeBrowser.commands",
          "group": "navigation@6"
        },
        {
          "command": "claudeCodeBrowser.marketplace.refresh",
          "when": "view == claudeCodeBrowser.marketplace",
          "group": "navigation@1"
        },
        {
          "command": "claudeCodeBrowser.marketplace.addSource",
          "when": "view == claudeCodeBrowser.marketplace",
          "group": "navigation@2"
        },
        {
          "command": "claudeCodeBrowser.hooks.add",
          "when": "view == claudeCodeBrowser.hookManager",
          "group": "navigation@0"
        },
        {
          "command": "claudeCodeBrowser.refreshHookManager",
          "when": "view == claudeCodeBrowser.hookManager",
          "group": "navigation@1"
        },
        {
          "command": "claudeCodeBrowser.refreshAgentTeams",
          "when": "view == claudeCodeBrowser.agentTeams",
          "group": "navigation@1"
        },
        {
          "command": "claudeCodeBrowser.worktree.create",
          "when": "view == claudeCodeBrowser.worktrees",
          "group": "navigation@0"
        },
        {
          "command": "claudeCodeBrowser.worktree.launchTask",
          "when": "view == claudeCodeBrowser.worktrees",
          "group": "navigation@1"
        },
        {
          "command": "claudeCodeBrowser.refreshWorktrees",
          "when": "view == claudeCodeBrowser.worktrees",
          "group": "navigation@2"
        },
        {
          "command": "claudeCodeBrowser.managePanels",
          "when": "view =~ /claudeCodeBrowser\\./",
          "group": "navigation@10"
        }
      ],
      "view/item/context": [
        {
          "command": "claudeCodeBrowser.renameFolder",
          "when": "viewItem == folder",
          "group": "1_folder@1"
        },
        {
          "command": "claudeCodeBrowser.deleteFolder",
          "when": "viewItem == folder",
          "group": "1_folder@2"
        },
        {
          "command": "claudeCodeBrowser.createSubfolder",
          "when": "viewItem == folder",
          "group": "1_folder@0"
        },
        {
          "command": "claudeCodeBrowser.exportBundle",
          "when": "viewItem == folder && view == claudeCodeBrowser.skills",
          "group": "1_folder@3"
        },
        {
          "command": "claudeCodeBrowser.previewSkill",
          "when": "viewItem =~ /^skill-(project|global)(-updatable)?$/",
          "group": "0_skill@1"
        },
        {
          "command": "claudeCodeBrowser.convertToGlobalSkill",
          "when": "viewItem == skill-project || viewItem == skill-project-updatable",
          "group": "0_skill@2"
        },
        {
          "command": "claudeCodeBrowser.editSkill",
          "when": "viewItem =~ /^skill-(project|global)(-updatable)?$/",
          "group": "0_skill@3"
        },
        {
          "command": "claudeCodeBrowser.duplicateSkill",
          "when": "viewItem =~ /^skill-(project|global)(-updatable)?$/",
          "group": "1_manage@1"
        },
        {
          "command": "claudeCodeBrowser.renameSkill",
          "when": "viewItem =~ /^skill-(project|global)(-updatable)?$/",
          "group": "1_manage@2"
        },
        {
          "command": "claudeCodeBrowser.revealInFinder",
          "when": "viewItem =~ /^skill-(project|global)(-updatable)?$/",
          "group": "1_manage@3"
        },
        {
          "command": "claudeCodeBrowser.copyPath",
          "when": "viewItem =~ /^skill-(project|global)(-updatable)?$/",
          "group": "1_manage@4"
        },
        {
          "command": "claudeCodeBrowser.exportBundle",
          "when": "viewItem =~ /^skill-(project|global)(-updatable)?$/",
          "group": "1_manage@5"
        },
        {
          "command": "claudeCodeBrowser.deleteSkill",
          "when": "viewItem =~ /^skill-(project|global)(-updatable)?$/",
          "group": "3_destructive@1"
        },
        {
          "command": "claudeCodeBrowser.generateResearchPrompt",
          "when": "view == claudeCodeBrowser.skills",
          "group": "0_create@1"
        },
        {
          "command": "claudeCodeBrowser.previewAgent",
          "when": "viewItem == agent",
          "group": "0_agent@1"
        },
        {
          "command": "claudeCodeBrowser.editAgent",
          "when": "viewItem == agent",
          "group": "0_agent@2"
        },
        {
          "command": "claudeCodeBrowser.duplicateAgent",
          "when": "viewItem == agent",
          "group": "1_manage@1"
        },
        {
          "command": "claudeCodeBrowser.renameAgent",
          "when": "viewItem == agent",
          "group": "1_manage@2"
        },
        {
          "command": "claudeCodeBrowser.revealInFinder",
          "when": "viewItem == agent",
          "group": "1_manage@3"
        },
        {
          "command": "claudeCodeBrowser.copyPath",
          "when": "viewItem == agent",
          "group": "1_manage@4"
        },
        {
          "command": "claudeCodeBrowser.deleteAgent",
          "when": "viewItem == agent",
          "group": "3_destructive@1"
        },
        {
          "command": "claudeCodeBrowser.previewMcp",
          "when": "viewItem == mcp",
          "group": "0_mcp@1"
        },
        {
          "command": "claudeCodeBrowser.revealInFinder",
          "when": "viewItem == skill-file || viewItem == skill-directory",
          "group": "1_manage@1"
        },
        {
          "command": "claudeCodeBrowser.copyPath",
          "when": "viewItem == skill-file || viewItem == skill-directory",
          "group": "1_manage@2"
        },
        {
          "command": "claudeCodeBrowser.moveToFolder",
          "when": "viewItem =~ /^skill-(project|global)(-updatable)?$/ || viewItem == agent || viewItem == mcp || viewItem == plugin",
          "group": "2_move@1"
        },
        {
          "command": "claudeCodeBrowser.moveToRoot",
          "when": "viewItem =~ /^skill-(project|global)(-updatable)?$/ || viewItem == agent || viewItem == mcp || viewItem == plugin",
          "group": "2_move@2"
        },
        {
          "command": "claudeCodeBrowser.editPrompt",
          "when": "viewItem == customPrompt",
          "group": "1_prompt@1"
        },
        {
          "command": "claudeCodeBrowser.deletePrompt",
          "when": "viewItem == customPrompt",
          "group": "1_prompt@2"
        },
        {
          "command": "claudeCodeBrowser.marketplace.installSkill",
          "when": "viewItem == marketplace-skill || viewItem == marketplace-skill-installed",
          "group": "1_marketplace@1"
        },
        {
          "command": "claudeCodeBrowser.marketplace.viewOnGitHub",
          "when": "viewItem == marketplace-skill || viewItem == marketplace-skill-installed",
          "group": "1_marketplace@2"
        },
        {
          "command": "claudeCodeBrowser.marketplace.removeSource",
          "when": "viewItem == marketplace-source",
          "group": "1_marketplace@1"
        },
        {
          "command": "claudeCodeBrowser.marketplace.refreshSource",
          "when": "viewItem == marketplace-source",
          "group": "1_marketplace@2"
        },
        {
          "command": "claudeCodeBrowser.marketplace.installSourceSkill",
          "when": "viewItem == marketplace-source-skill || viewItem == marketplace-source-skill-installed",
          "group": "1_marketplace@1"
        },
        {
          "command": "claudeCodeBrowser.marketplace.viewSourceSkillOnGitHub",
          "when": "viewItem == marketplace-source-skill || viewItem == marketplace-source-skill-installed",
          "group": "1_marketplace@2"
        },
        {
          "command": "claudeCodeBrowser.previewSkill",
          "when": "viewItem =~ /^skill-(project|global)(-updatable)?$/",
          "group": "inline"
        },
        {
          "command": "claudeCodeBrowser.skills.updateSkill",
          "when": "viewItem == skill-global-updatable || viewItem == skill-project-updatable",
          "group": "inline"
        },
        {
          "command": "claudeCodeBrowser.skills.updateSkill",
          "when": "viewItem == skill-global-updatable || viewItem == skill-project-updatable",
          "group": "0_skill@0"
        },
        {
          "command": "claudeCodeBrowser.previewAgent",
          "when": "viewItem == agent",
          "group": "inline"
        },
        {
          "command": "claudeCodeBrowser.previewMcp",
          "when": "viewItem == mcp",
          "group": "inline"
        },
        {
          "command": "claudeCodeBrowser.hooks.edit",
          "when": "viewItem == hook-item",
          "group": "0_hook@1"
        },
        {
          "command": "claudeCodeBrowser.hooks.duplicate",
          "when": "viewItem == hook-item",
          "group": "0_hook@2"
        },
        {
          "command": "claudeCodeBrowser.hooks.toggle",
          "when": "viewItem == hook-item || viewItem == hook-item-disabled",
          "group": "0_hook@3"
        },
        {
          "command": "claudeCodeBrowser.hooks.openFile",
          "when": "viewItem == hook-item || viewItem == hook-item-disabled || viewItem == hook-event",
          "group": "1_hookFile@1"
        },
        {
          "command": "claudeCodeBrowser.hooks.delete",
          "when": "viewItem == hook-item || viewItem == hook-item-disabled",
          "group": "2_destructive@1"
        },
        {
          "command": "claudeCodeBrowser.hooks.add",
          "when": "viewItem == hook-event",
          "group": "0_hook@1"
        },
        {
          "command": "claudeCodeBrowser.agentTeams.watch",
          "when": "viewItem == agent-team-member",
          "group": "0_agent@1"
        },
        {
          "command": "claudeCodeBrowser.agentTeams.watch",
          "when": "viewItem == agent-team-member",
          "group": "inline"
        },
        {
          "command": "claudeCodeBrowser.worktree.resume",
          "when": "viewItem == worktree || viewItem == worktree-active",
          "group": "0_worktree@1"
        },
        {
          "command": "claudeCodeBrowser.worktree.openInEditor",
          "when": "viewItem == worktree || viewItem == worktree-active",
          "group": "0_worktree@2"
        },
        {
          "command": "claudeCodeBrowser.worktree.delete",
          "when": "viewItem == worktree || viewItem == worktree-active",
          "group": "2_destructive@1"
        },
        {
          "command": "claudeCodeBrowser.worktree.openInEditor",
          "when": "viewItem == worktree || viewItem == worktree-active",
          "group": "inline"
        }
      ]
    },
    "configurationDefaults": {
      "workbench.tree.indent": 20
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^18",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.0.0"
  }
}
